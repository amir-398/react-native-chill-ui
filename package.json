{
  "name": "chill-ui",
  "version": "1.0.0",
  "description": "Chill UI is a library of components for react native",
  "keywords": [
    "react-native",
    "ui",
    "components",
    "react-native-components",
    "react-native-ui",
    "react-native-components"
  ],
  "homepage": "https://github.com/amirmeb/chill-ui",
  "bugs": {
    "url": "https://github.com/amirmeb/chill-ui/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/onmotion/react-native-autocomplete-dropdown.git"
  },
  "license": "MIT",
  "author": "Amir Meberbeche <amir.meb398@gmail.com>",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "source": "src/index",
  "react-native": "src/index",
  "types": "lib/typescript/index.d.ts",
  "files": [
    "lib",
    "src"
  ],
  "scripts": {
    "build": "bob build",
    "clean": "del-cli lib",
    "prepack": "cp -r chill-ui-watch/src src",
    "postpack": "rm -rf src",
    "example": "yarn workspace react-native-awesome-library-example",
    "lint": "eslint .",
    "release": "release-it",
    "test": "echo \"Error: no test specified\" && exit 1",
    "tsc": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@commitlint/config-conventional": "^17.0.0",
    "@react-native-async-storage/async-storage": "^2.1.2",
    "@react-native-community/cli": "18.0.0",
    "@react-native-community/cli-platform-android": "18.0.0",
    "@react-native-community/cli-platform-ios": "18.0.0",
    "@react-native/babel-preset": "0.79.2",
    "@react-native/eslint-config": "0.79.2",
    "@react-native/metro-config": "0.79.2",
    "@react-native/typescript-config": "0.79.2",
    "@types/jest": "^29.5.13",
    "@types/react-test-renderer": "^19.0.0",
    "clsx": "^2.1.1",
    "commitlint": "^17.0.2",
    "del-cli": "^5.1.0",
    "eslint": "^8.19.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-expo": "^9.2.0",
    "eslint-config-prettier": "^10.1.3",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-perfectionist": "^4.13.0",
    "eslint-plugin-prettier": "^5.4.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "jest": "^29.6.3",
    "lefthook": "^1.11.12",
    "prettier": "^3.0.0",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "react": "19.0.0",
    "react-native": "0.79.2",
    "react-native-builder-bob": "^0.30.2",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "^5.4.1",
    "react-native-webview": "^13.13.5",
    "react-test-renderer": "19.0.0",
    "release-it": "^15.0.0",
    "tailwind-merge": "^3.3.0",
    "tailwind-variants": "^1.0.0",
    "tailwindcss": "^3.4.17",
    "typescript": "5.1.6"
  },
  "peerDependencies": {
    "clsx": "*",
    "react": "*",
    "react-native": "*",
    "react-native-reanimated": "*",
    "react-native-safe-area-context": "*",
    "react-native-svg": "*",
    "react-native-webview": "*",
    "tailwind-merge": "*",
    "tailwind-variants": "*",
    "tailwindcss": "*"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "react-native-builder-bob": {
    "source": "chill-ui-watch/src",
    "output": "lib",
    "exclude": [
      "example/**",
      ".storybook/**",
      "stories/**",
      "node_modules/**",
      "dist/**",
      "assets/**",
      ".expo/**"
    ],
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "release-it": {
    "git": {
      "commitMessage": "Release ${version}",
      "tagName": "v${version}"
    },
    "npm": {
      "publish": true
    },
    "github": {
      "release": true
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": "angular"
      }
    }
  },
  "dependencies": {
    "react-native-gesture-handler": "^2.25.0"
  }
}
